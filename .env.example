DISCORD_TOKEN=replace_with_your_bot_token
DISCORD_CLIENT_ID=

# Optional: use this while developing so slash commands update instantly in one server.
DISCORD_GUILD_ID=
WELCOME_CHANNEL_ID=
AUTO_REGISTER_COMMANDS=true
# Comma-separated activity texts. Falls back to PRESENCE_TEXT for compatibility.
PRESENCE_TEXTS=Keeping UNDR CTRL connected.,Watching the community grow.
PRESENCE_TEXT=Keeping UNDR CTRL connected.
# Minimum 5 seconds.
PRESENCE_ROTATION_SECONDS=30

# Browser dashboard.
DASHBOARD_ENABLED=true
DASHBOARD_PASSWORD=replace_with_a_long_private_password
DASHBOARD_MAX_BODY_MB=12
DASHBOARD_MAX_UPLOAD_MB=8
# Optional override. Railway sets RAILWAY_VOLUME_MOUNT_PATH automatically when a volume is attached.
DASHBOARD_SAVED_MESSAGES_PATH=
# Optional presence settings file override. Uses the Railway volume automatically when attached.
DASHBOARD_PRESENCE_PATH=

# Optional privileged intents. Enable these only after enabling the same toggles in the Discord Developer Portal.
ENABLE_SERVER_MEMBERS_INTENT=false
ENABLE_MESSAGE_CONTENT_INTENT=false
ENABLE_PRESENCE_INTENT=false

# Optional branding text for /about.
COMMUNITY_NAME=UNDR CTRL
COMMUNITY_DESCRIPTION=A community for UNDR CTRL members to connect, create, and build together.

# Optional channel IDs.
GUIDELINES_CHANNEL_ID=
INTRODUCTIONS_CHANNEL_ID=
RULES_CHANNEL_ID=
SOCIALS_CHANNEL_ID=
TICKET_CHANNEL_ID=
TICKET_LOG_CHANNEL_ID=
MEMBER_LOG_CHANNEL_ID=
MESSAGE_LOG_CHANNEL_ID=
CHANNEL_LOG_CHANNEL_ID=
EVENT_LOG_CHANNEL_ID=
INVITE_LOG_CHANNEL_ID=
MOD_LOG_CHANNEL_ID=
USER_LOG_CHANNEL_ID=
ANNOUNCEMENT_CHANNEL_ID=

# Optional role IDs.
STAFF_ROLE_ID=
MODERATOR_ROLE_ID=
VERIFIED_ROLE_ID=
STREAM_WHITELIST_ROLE_ID=
LIVE_ROLE_ID=

# Optional reaction role setup.
REACTION_ROLE_CHANNEL_ID=
REACTION_ROLE_MESSAGE_ID=
REACTION_ROLE_EMOJI_ID=

# Optional invite moderation.
INVITE_MODERATION_ENABLED=false
ALLOWED_INVITE_PATTERNS=
INVITE_TIMEOUT_MS=60000

# Optional stream monitor.
STREAM_MONITOR_ENABLED=false
STREAM_TITLE_KEYWORD=UNDR CTRL
STREAM_GAME_NAME_INCLUDES=
